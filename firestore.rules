rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'pankaj.rai@flick2know.com';
    }

    // Stage-1 legacy blob (used only for one-time migration).
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /agents/{id} {
      // You can read your own agents, any org-shared agent, and (if admin) everything.
      allow read: if request.auth != null && (
        resource.data.ownerUid == request.auth.uid ||
        resource.data.visibility == 'org' ||
        isAdmin()
      );

      // Anyone signed in can create — but only as a PERSONAL agent they own.
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.visibility == 'personal';

      // Owners can edit their own agent's content and request org-wide,
      // but cannot change visibility themselves. Only the admin can publish/unpublish.
      allow update: if request.auth != null && (
        isAdmin() ||
        (resource.data.ownerUid == request.auth.uid
         && request.resource.data.ownerUid == resource.data.ownerUid
         && request.resource.data.visibility == resource.data.visibility)
      );

      // Owner or admin can delete.
      allow delete: if request.auth != null && (isAdmin() || resource.data.ownerUid == request.auth.uid);
    }
  }
}
